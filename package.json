{
  "name": "@pruefertit/docker-orchestrator",
  "version": "0.1.0",
  "description": "TypeScript-first Docker orchestration library for programmatic container lifecycle management, monitoring, networking, and resilient operations.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build && npm run typecheck",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:perf": "vitest run --config vitest.config.perf.ts",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "docker",
    "orchestration",
    "containers",
    "typescript",
    "dockerode",
    "devops"
  ],
  "license": "MIT",
  "homepage": "https://github.com/pruefertit/docker-orchestrator#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/pruefertit/docker-orchestrator.git"
  },
  "bugs": {
    "url": "https://github.com/pruefertit/docker-orchestrator/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/dockerode": "^3.3.31",
    "@types/node": "^20.0.0",
    "@types/tar-stream": "^3.1.4",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "dockerode": "^4.0.0",
    "eventemitter3": "^5.0.0",
    "tar-stream": "^3.1.7",
    "zod": "^3.23.0"
  }
}
